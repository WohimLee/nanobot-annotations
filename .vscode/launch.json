    {
      "name": "nanobot: status",
      "type": "debugpy",
      "request": "launch",
      "module": "nanobot",
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "justMyCode": true,
      "args": ["status"]
    },
    {
      "name": "nanobot: channels status",
      "type": "debugpy",
      "request": "launch",
      "module": "nanobot",
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "justMyCode": true,
      "args": ["channels", "status"]
    },
    {
      "name": "nanobot: channels login",
      "type": "debugpy",
      "request": "launch",
      "module": "nanobot",
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "justMyCode": true,
      "args": ["channels", "login"]
    }
  ]
